{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bookgenerators-web",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/agents/*"]
  },

  "observability": { "enabled": true, "head_sampling_rate": 1 },
  "upload_source_maps": true,

  "routes": [
    { "pattern": "book-cook.com", "custom_domain": true },
    { "pattern": "www.book-cook.com", "custom_domain": true }
  ],

  "vars": {
    "ENV": "dev",
    "DEFAULT_MODEL": "@cf/zai-org/glm-4.7-flash",
    "RESEARCH_MODEL": "anthropic/claude-opus-4-7",
    "IMAGE_MODEL": "openai/gpt-image-2",
    "AI_GATEWAY_ID": "x",
    "POSTPILOT_BASE_URL": "https://postpilot.cc",
    "BETTER_AUTH_URL": "https://book-cook.com",
    "GOOGLE_CLIENT_ID": "28692687396-450mrtd8csaa8rnef13hteq902sb3g8n.apps.googleusercontent.com"
  },

  // Secrets (provision via scripts/bootstrap.sh):
  //   BETTER_AUTH_SECRET
  //   AI_GATEWAY_BASE_URL
  //   AI_GATEWAY_TOKEN
  //   S3_ACCESS_KEY_ID
  //   S3_SECRET_ACCESS_KEY
  //   RENDER_WORKER_INTERNAL_TOKEN
  //   KEYRING_MASTER_KEY
  //   GOOGLE_CLIENT_SECRET

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bookgenerators",
      "database_id": "12308aa2-4101-4c20-8cce-fd0fd7a85a48",
      "migrations_dir": "drizzle"
    }
  ],
  "kv_namespaces": [{ "binding": "KV", "id": "550e0e2af0c9454c8e256d94fcac4d47" }],
  "r2_buckets": [{ "binding": "R2", "bucket_name": "bookgenerators" }],
  "ai": { "binding": "AI" },

  "durable_objects": {
    "bindings": [{ "name": "ALOYSIUS", "class_name": "BookProjectAgent" }]
  },

  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["BookProjectAgent"] }]

  // containers binding wired in Publisher phase (Plan 4) once render-worker
  // is pushed to a registry and the Container DO class is defined.
  // "containers": [{ "name": "RENDER_WORKER", "class_name": "RenderWorkerContainer",
  //   "image": "ghcr.io/bookgenerators/render-worker:latest", "max_instances": 4 }]
}
